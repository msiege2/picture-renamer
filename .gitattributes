# Auto-detect text files and normalize line endings to LF in the repo.
# Working copies on Windows will get CRLF, on Linux/macOS will get LF.
* text=auto

# Source code — always LF in repo
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.sh text eol=lf

# Windows-specific — always CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line ending conversion
*.jar binary
*.exe binary
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
